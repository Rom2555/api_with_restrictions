# примеры API-запросов

@baseUrl = http://localhost:8000/api

# получение объявлений
GET {{baseUrl}}/advertisements/
Content-Type: application/json

###

# создание объявления, токен admin
POST {{baseUrl}}/advertisements/
Content-Type: application/json
Authorization: Token 40aa1dc45d0b456a3f0f79491d85811c02d18566

{
  "title": "Шкаф IKEA",
  "description": "Срочно"
}

###

# попытка поменять объявление, токен ivanov
PATCH {{baseUrl}}/advertisements/1/
Content-Type: application/json
Authorization: Token b60c5784f5d38732e8968fc2360162ecbd3ef098

{
  "status": "CLOSED"
}

###

# фильтрация по создателю
GET {{baseUrl}}/advertisements/?creator=3
Content-Type: application/json

###

# фильтрация по дате
GET {{baseUrl}}/advertisements/?created_at_before=2020-10-01
Content-Type: application/json
